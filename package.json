{
  "name": "uni-status",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @uni-status/database db:studio",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "enterprise"
  ],
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "@hono/node-server": ">=1.19.10",
      "@hono/zod-openapi": "1.2.2",
      "@asteasolutions/zod-to-openapi": "8.4.3",
      "eslint>ajv": "6.12.6",
      "esbuild": ">=0.25.0",
      "fast-xml-parser": ">=5.5.7",
      "flatted": ">=3.4.2",
      "hono": ">=4.12.7",
      "kysely": ">=0.28.12",
      "lodash": ">=4.17.23",
      "minimatch": ">=3.1.4",
      "next": ">=16.1.7",
      "rollup": ">=4.59.0",
      "socket.io-parser": ">=4.2.6",
      "undici": ">=7.24.0"
    }
  }
}
