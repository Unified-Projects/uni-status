{
  "name": "@uni-status/email",
  "version": "0.2.7",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./templates/*": {
      "types": "./src/templates/*.tsx",
      "default": "./src/templates/*.tsx"
    }
  },
  "scripts": {
    "dev": "email dev --dir ./src/templates",
    "build": "email export --dir ./src/templates --outDir ./dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@uni-status/shared": "workspace:*",
    "nodemailer": "^8.0.5",
    "react-email": "^5.2.10",
    "resend": "^6.11.0"
  },
  "devDependencies": {
    "@react-email/preview-server": "^5.2.10",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": "^19"
  }
}
