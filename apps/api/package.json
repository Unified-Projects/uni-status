{
  "name": "@uni-status/api",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external puppeteer --external @aws-sdk/client-s3",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@resvg/resvg-js": "^2.6.2",
    "@uni-status/auth": "workspace:*",
    "@uni-status/database": "workspace:*",
    "@uni-status/email": "workspace:*",
    "@uni-status/enterprise": "workspace:*",
    "@uni-status/shared": "workspace:*",
    "bullmq": "^5.73.0",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "hono": "^4.12.11",
    "ioredis": "5.10.1",
    "nanoid": "^5.1.7",
    "puppeteer": "^24.39.1",
    "react": "^19.2.4",
    "satori": "^0.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.11",
    "typescript": "^5.7.3"
  }
}
